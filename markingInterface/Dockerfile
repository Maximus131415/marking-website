# Указывает базовый образ: легкая версия Linux (Alpine) с предустановленной Node.js 18
FROM node:18-alpine

# Создает рабочую директорию внутри контейнера, где будут лежать все файлы
WORKDIR /app

# Копирует файлы со списками зависимостей (package.json и package-lock.json) в контейнер
COPY package*.json ./

# Запускает установку всех библиотек, указанных в package.json
RUN npm install

# Копирует все остальные файлы и папки из текущей директории в контейнер
COPY . .

# Сообщает Docker, что контейнер будет использовать порт 3003
EXPOSE 3003

# Команда, которая запустится при старте контейнера (запуск сервера разработки)
CMD ["npm", "run", "dev"]
